# ====================C++ IM Gateway - 测试环境配置========================



# 环境标识
NODE_ENV=test
APP_NAME=cpp-im-gateway-test

# 服务器配置
PORT=8080
EXTERNAL_PORT=18080         # 测试环境用不同端口，避免冲突
MAX_CONNECTIONS=1000        # 测试更大的连接数
THREAD_POOL_SIZE=8

# 日志配置
LOG_LEVEL=info              # 测试环境适中详细度
LOG_TO_FILE=true            # 输出到文件便于分析
LOG_FORMAT=json             # JSON格式便于机器解析
LOG_FILE=/app/logs/test.log

# 性能配置
ENABLE_PROFILING=true       # 测试时也需要性能分析
ENABLE_DEBUG_SYMBOLS=false  # 测试环境不需要调试符号
OPTIMIZATION_LEVEL=2        # 中等优化

# Docker配置
RESTART_POLICY=on-failure   # 失败时重启
HEALTH_CHECK_INTERVAL=10s   # 健康检查
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=3
DOCKER_NETWORK=bridge

# 测试特定配置
ENABLE_METRICS=true         # 启用指标收集
METRICS_PORT=9090           # Prometheus指标端口
TEST_DURATION=60            # 测试持续时间（秒）
CONCURRENT_CLIENTS=50       # 并发客户端数
